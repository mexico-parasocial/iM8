{
  "lexicon": 1,
  "id": "app.m8.community.manifesto",
  "defs": {
    "main": {
      "type": "record",
      "description": "Community manifesto document.",
      "key": "literal:self",
      "record": {
        "type": "object",
        "required": ["text", "updatedAt"],
        "properties": {
          "text": { "type": "string", "maxLength": 50000 },
          "version": { "type": "integer", "minimum": 1 },
          "updatedAt": { "type": "string", "format": "datetime" },
          "actionUri": { "type": "string", "format": "at-uri", "description": "URI of the governance action that approved this manifesto" }
        }
      }
    }
  }
}
