NODE_ENV=development
PORT=8787
HOST=0.0.0.0
SERVICE_URL=http://localhost:8787
DATABASE_PATH=./data/identity-manager.db
JWT_SECRET=change-me-min-32-chars-long-secret
APP_KEY=change-me-16-chars
COOKIE_SECRET=change-me-min-16-chars-long-cookie-secret
PLC_URL=https://plc.directory
PDS_URL=https://bsky.social
# PRIVATE_KEYS=[{"kty":"EC","crv":"P-256",...}] # JWK array for confidential OAuth client
IDENTITY_ISSUER_DID=did:m8:ine:emisor-001
# Ed25519 JWKs for durable credential signing in production.
IDENTITY_ISSUER_PRIVATE_JWK=
IDENTITY_ISSUER_PUBLIC_JWK=
IDENTITY_ISSUER_KEY_ID=ine-ed25519-2026-01
# Previous key material for rotation grace period (verification only, no signing).
# Set IDENTITY_ISSUER_PREVIOUS_KEY_EXPIRES_AT to an ISO datetime to auto-expire trust.
IDENTITY_ISSUER_PREVIOUS_PUBLIC_JWK=
IDENTITY_ISSUER_PREVIOUS_KEY_ID=
IDENTITY_ISSUER_PREVIOUS_KEY_EXPIRES_AT=
# Comma-separated key ids that must be rejected immediately.
IDENTITY_ISSUER_REVOKED_KEY_IDS=
LOG_LEVEL=info
CORS_ORIGIN=*
PARA_API_BASE_URL=
# Security & rate limiting
SECURITY_HEADERS_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_COMMUNITY_READ_MAX=120
RATE_LIMIT_COMMUNITY_MUTATION_MAX=20
RATE_LIMIT_COMMUNITY_VOTE_MAX=30
JSON_BODY_MAX_SIZE=1mb
# Break-glass: set to 'enabled' to force-open demo/simulated/dev paths in production.
# This should never be set in normal production deployments.
BREAK_GLASS_DEMO_PATHS=
PARA_API_TIMEOUT_MS=5000
GROWTHBOOK_API_HOST=
GROWTHBOOK_CLIENT_KEY=
GROWTHBOOK_INIT_TIMEOUT_MS=2000
# Optional local JSON overrides, e.g.
# GROWTHBOOK_FEATURE_OVERRIDES={"m8:auth:dev_token_bootstrap":true}
GROWTHBOOK_FEATURE_OVERRIDES=
