{
  "name": "@m8/identity-manager",
  "version": "0.1.0",
  "description": "M8 Identity Manager — proof broker, credential wallet, and trust policy service",
  "type": "module",
  "main": "build/bin/server.js",
  "scripts": {
    "build": "node ace build && cp -r src/i18n/locales build/src/i18n/locales",
    "start": "node --enable-source-maps build/bin/server.js",
    "dev": "node ace serve --watch",
    "test": "NODE_ENV=test node --test build/tests/**/*.test.js",
    "test:integration": "NODE_ENV=test tsx --test --test-force-exit tests/integration/**/*.test.ts",
    "test:e2e": "NODE_ENV=test tsx --test tests/e2e/**/*.test.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "m8:deploy": "npm run build && node build/src/db/migrate.js",
    "ace": "node ace",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@adonisjs/core": "^7.3.3",
    "@adonisjs/cors": "^3.0.0",
    "@adonisjs/lucid": "^22.4.2",
    "@atproto/identity": "^0.4.12",
    "@atproto/oauth-client-node": "^0.3.13",
    "@vinejs/vine": "^4.4.0",
    "better-sqlite3": "^12.0.0",
    "circomlibjs": "^0.1.7",
    "dotenv": "^16.4.0",
    "jose": "^6.2.3",
    "reflect-metadata": "^0.2.2",
    "snarkjs": "^0.7.6",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.4.0",
    "@adonisjs/tsconfig": "^2.0.0",
    "@poppinss/ts-exec": "^1.4.4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#support/*": "./app/support/*.js",
    "#config/*": "./config/*.js",
    "#start/*": "./start/*.js",
    "#src/*": "./src/*.js"
  }
}
