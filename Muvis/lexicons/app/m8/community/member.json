{
  "lexicon": 1,
  "id": "app.m8.community.member",
  "defs": {
    "main": {
      "type": "record",
      "description": "A member record stored in the community's repo.",
      "key": "did",
      "record": {
        "type": "object",
        "required": ["memberDid", "status", "joinedAt"],
        "properties": {
          "memberDid": { "type": "string", "format": "did" },
          "status": { "type": "ref", "ref": "app.m8.community.defs#membershipStatus" },
          "joinedAt": { "type": "string", "format": "datetime" },
          "approvedBy": { "type": "array", "items": { "type": "string", "format": "did" } }
        }
      }
    }
  }
}
